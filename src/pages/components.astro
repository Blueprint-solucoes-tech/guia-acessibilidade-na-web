---
import DefaultLayout from '~/layouts/DefaultLayout.astro'
import Breadcrumbs from '~/components/core/Breadcrumbs/Breadcrumbs.astro'
import BreadcrumbsItem from '~/components/core/Breadcrumbs/BreadcrumbsItem.astro'
import Heading from '~/components/core/Heading.astro'
import AccordionSection from '~/components/ui/ComponentReference/AccordionSection.astro'
import AvatarSection from '~/components/ui/ComponentReference/AvatarSection.astro'
import BadgeSection from '~/components/ui/ComponentReference/BadgeSection.astro'
import BreadcrumbsSection from '~/components/ui/ComponentReference/BreadcrumbsSection.astro'
import ButtonSection from '~/components/ui/ComponentReference/ButtonSection.astro'
import CardSection from '~/components/ui/ComponentReference/CardSection.astro'
import ComponentPlaceholder from '~/components/ui/ComponentReference/ComponentPlaceholder.astro'
import FormSection from '~/components/ui/ComponentReference/FormSection.astro'
import HeadingSection from '~/components/ui/ComponentReference/HeadingSection.astro'
import LinkSection from '~/components/ui/ComponentReference/LinkSection.astro'
import MediaSection from '~/components/ui/ComponentReference/MediaSection.astro'
import { componentSections } from '~/components/ui/ComponentReference/componentSections'
---

<DefaultLayout title="Componentes Acessíveis">
  <section class="components-header">
    <div class="container">
      <div class="header-breadcrumbs">
        <Breadcrumbs ariaLabel="Caminho da página de componentes">
          <BreadcrumbsItem href="/" label="Início" />
          <BreadcrumbsItem currentPage label="Componentes acessíveis" />
        </Breadcrumbs>
      </div>
      <div class="header-content space-content">
        <Heading level="h1">Componentes acessíveis</Heading>
        <p>
          Esta página está evoluindo para ser uma referência técnica de implementação. O objetivo é combinar exemplo,
          contexto de uso, riscos comuns e critérios de teste em um só lugar.
        </p>
      </div>
    </div>
  </section>

  <section class="components-content">
    <div class="container content-grid">
      <div class="main-content">
        <AccordionSection />
        <AvatarSection />
        <BadgeSection />
        <BreadcrumbsSection />
        <ButtonSection />
        <CardSection />
        <ComponentPlaceholder id="dark-mode-toggle" label="Dark mode toggle" />
        <FormSection />
        <HeadingSection />
        <ComponentPlaceholder id="high-contrast-toggle" label="High contrast toggle" />
        <LinkSection />
        <MediaSection />
      </div>

      <aside class="toc" aria-labelledby="toc-title">
        <div class="toc-wrapper">
          <Heading id="toc-title" level="h2" size="h4">Nesta página</Heading>
          <nav aria-label="Índice de componentes">
            <ul>
              {componentSections.map((item) => (
                <li>
                  <a href={`#${item.id}`}>{item.label}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>
    </div>
  </section>
</DefaultLayout>

<style>
  .components-header {
    border-block: 1px solid var(--border-color-subtle);
    padding-block: var(--space-xl);
    background: linear-gradient(180deg, hsl(210deg 95% 4%) 0%, hsl(212deg 95% 5%) 100%);
    color: hsl(0deg 0% 95%);
  }

  .darkmode .components-header {
    background: linear-gradient(180deg, hsl(210deg 95% 4%) 0%, hsl(212deg 95% 5%) 100%);
  }

  .components-header .header-breadcrumbs {
    margin-block-end: var(--space-xl);
    color: hsl(0deg 0% 90%);
  }

  .components-header :global(a) {
    color: hsl(177deg 82% 62%);
  }

  .components-header .header-content {
    max-inline-size: 75ch;
  }

  .components-content {
    padding-block: var(--space-3xl);
  }

  .content-grid {
    display: grid;
    gap: var(--space-2xl);
  }

  .main-content {
    display: grid;
    gap: var(--space-2xl);
  }

  .toc {
    border-inline-start: 1px solid var(--border-color-subtle);
    padding-inline-start: var(--space-m);
  }

  .toc-wrapper {
    position: sticky;
    top: 1.5rem;
  }

  .toc ul {
    display: grid;
    gap: var(--space-xs);
    margin: var(--space-s) 0 0;
    padding: 0;
    list-style: none;
  }

  @media (width >= 64rem) {
    .content-grid {
      grid-template-columns: minmax(0, 1fr) 18rem;
      align-items: start;
    }
  }

  @media (width < 64rem) {
    .toc {
      border-inline-start: 0;
      border-block-start: 1px solid var(--border-color-subtle);
      padding-inline-start: 0;
      padding-block-start: var(--space-l);
    }
  }
</style>
