---
import { getCollection } from 'astro:content'
import DefaultLayout from '~/layouts/DefaultLayout.astro'
import Breadcrumbs from '~/components/core/Breadcrumbs/Breadcrumbs.astro'
import BreadcrumbsItem from '~/components/core/Breadcrumbs/BreadcrumbsItem.astro'
import Heading from '~/components/core/Heading.astro'
import Link from '~/components/core/Link.astro'

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<DefaultLayout
  title="Blog"
  description="Artigos práticos sobre implementação, validação e revisão de acessibilidade na web."
>
  <section class="blog-header">
    <div class="container">
      <div class="header-breadcrumbs">
        <Breadcrumbs ariaLabel="Caminho da página de blog">
          <BreadcrumbsItem href="/" label="Início" />
          <BreadcrumbsItem currentPage label="Blog" />
        </Breadcrumbs>
      </div>

      <div class="header-content space-content">
        <Heading level="h1">Blog</Heading>
        <p>
          Conteúdo editorial curto e conectado ao código do projeto. Cada artigo existe para aprofundar decisões
          práticas de acessibilidade, não para repetir teoria genérica.
        </p>
      </div>
    </div>
  </section>

  <section class="blog-listing">
    <div class="container">
      <p class="listing-meta">{posts.length} artigo{posts.length === 1 ? '' : 's'} publicado{posts.length === 1 ? '' : 's'}</p>

      <div class="posts-grid">
        {posts.map((post) => (
          <article class="post-card">
            <div class="post-content">
              <p class="post-tag">{post.data.category}</p>
              <Heading level="h2" size="h5">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </Heading>
              <p>{post.data.description}</p>
              <p class="post-meta">
                {post.data.pubDate.toLocaleDateString('pt-BR')} · {post.data.readingTime}
              </p>
              <Link href={`/blog/${post.id}/`}>Ler artigo</Link>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</DefaultLayout>

<style>
  .blog-header {
    border-block: 1px solid var(--border-color-subtle);
    padding-block: var(--space-xl);
  }

  .blog-header .header-breadcrumbs {
    margin-block-end: var(--space-xl);
  }

  .blog-header .header-content {
    max-inline-size: 72ch;
  }

  .blog-listing {
    padding-block: var(--space-3xl);
  }

  .listing-meta {
    margin-block-end: var(--space-s);
    color: var(--color-text-muted, currentColor);
  }

  .posts-grid {
    display: grid;
    gap: var(--space-l);
  }

  .post-card {
    border: 1px solid var(--border-color-subtle);
    border-radius: var(--radius-m);
    background: light-dark(hsl(210 40% 98%), hsl(214 20% 10%));
  }

  .post-content {
    display: grid;
    gap: var(--space-s);
    padding: var(--space-m);
  }

  .post-content :global(.heading) {
    line-height: 1.25;
  }

  .post-content :global(a) {
    inline-size: fit-content;
  }

  .post-tag {
    margin: 0;
    color: var(--link-color);
    font-size: var(--font-size--1);
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .post-meta {
    color: light-dark(hsl(215 15% 35%), hsl(215 12% 72%));
  }

  @media (width >= 48rem) {
    .posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
